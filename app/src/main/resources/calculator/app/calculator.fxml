<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="calculator.app.CalculatorController"
            styleClass="root-pane">

    <stylesheets>
        <URL value="@calculator.css" />
    </stylesheets>

    <top>
        <TextField fx:id="display"
                   editable="false"
                   text="0"
                   styleClass="display"
                   BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets top="20" right="20" bottom="10" left="20" />
            </BorderPane.margin>
        </TextField>
    </top>

    <center>
        <GridPane hgap="10" vgap="10" styleClass="button-grid">
            <padding>
                <Insets top="0" right="20" bottom="20" left="20" />
            </padding>

            <columnConstraints>
                <ColumnConstraints percentWidth="25" />
                <ColumnConstraints percentWidth="25" />
                <ColumnConstraints percentWidth="25" />
                <ColumnConstraints percentWidth="25" />
            </columnConstraints>

            <rowConstraints>
                <RowConstraints percentHeight="20" />
                <RowConstraints percentHeight="20" />
                <RowConstraints percentHeight="20" />
                <RowConstraints percentHeight="20" />
                <RowConstraints percentHeight="20" />
            </rowConstraints>

            <Button text="C" styleClass="btn-function" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="0" />
            <Button text="⌫" styleClass="btn-function" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1" />
            <Button text="%%" styleClass="btn-function" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="2" />
            <Button text="/" styleClass="btn-operator" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="3" />

            <Button text="7" styleClass="btn-digit" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="0" />
            <Button text="8" styleClass="btn-digit" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1" />
            <Button text="9" styleClass="btn-digit" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="2" />
            <Button text="*" styleClass="btn-operator" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="3" />

            <Button text="4" styleClass="btn-digit" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="0" />
            <Button text="5" styleClass="btn-digit" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="1" />
            <Button text="6" styleClass="btn-digit" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="2" />
            <Button text="-" styleClass="btn-operator" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="3" />

            <Button text="1" styleClass="btn-digit" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="0" />
            <Button text="2" styleClass="btn-digit" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="1" />
            <Button text="3" styleClass="btn-digit" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="2" />
            <Button text="+" styleClass="btn-operator" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="3" GridPane.columnIndex="3" />

            <Button text="+/-" styleClass="btn-function" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="0" />
            <Button text="0" styleClass="btn-digit" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="1" />
            <Button text="." styleClass="btn-digit" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="2" />
            <Button text="=" styleClass="btn-equals" maxWidth="Infinity" maxHeight="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="3" />

        </GridPane>
    </center>

</BorderPane>